# Copy this file to ".env" and fill in your real key(s).
# Never share your .env file or commit it to GitHub.

# This ONE Gemini key powers Gemini for every account that signs up —
# get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude is different: each person adds their OWN Claude key inside the
# app (Settings, after logging in), not here. Nothing to fill in below
# for Claude — this file is only for the shared Gemini key.

# Which port the server runs on (only change if 3000 is taken)
PORT=3000
